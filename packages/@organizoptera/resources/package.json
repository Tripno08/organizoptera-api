{
  "name": "@organizoptera/resources",
  "version": "1.0.0",
  "description": "Resource quota tracking and usage monitoring for Organizoptera",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@organizoptera/types": "workspace:*",
    "@organizoptera/core": "workspace:*",
    "@organizoptera/subscription": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  },
  "keywords": [
    "organizoptera",
    "resources",
    "quota",
    "usage",
    "monitoring"
  ],
  "license": "AGPL-3.0"
}
