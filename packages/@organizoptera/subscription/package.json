{
  "name": "@organizoptera/subscription",
  "version": "1.0.0",
  "description": "Subscription management for Organizoptera multi-tenant platform",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./service": {
      "import": {
        "types": "./dist/subscription-service.d.ts",
        "default": "./dist/subscription-service.js"
      },
      "require": {
        "types": "./dist/subscription-service.d.ts",
        "default": "./dist/subscription-service.js"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@organizoptera/types": "workspace:*",
    "@organizoptera/core": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  },
  "keywords": [
    "organizoptera",
    "subscription",
    "saas",
    "multi-tenant",
    "billing"
  ],
  "license": "AGPL-3.0"
}
