# Test Environment Configuration for E2E Tests
# Uses PostgreSQL container on Mac Mini (cogg-server: 192.168.15.6)

NODE_ENV=test
PORT=5002

# PostgreSQL Test Database (Mac Mini)
# User: cogg (not organizoptera)
DATABASE_URL="postgresql://cogg:dev_password@192.168.15.6:5432/cogg_organizoptera_test?schema=public"

# JWT Configuration
JWT_SECRET="test-jwt-secret-for-e2e-tests-only-do-not-use-in-production"
JWT_EXPIRES_IN="24h"

# Logging
LOG_LEVEL="error"
