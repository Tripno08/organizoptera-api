{
  "name": "@organizoptera/org-api",
  "version": "1.0.0",
  "description": "REST API service for Organizoptera",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "test:e2e": "dotenv -e .env.test -- vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "dotenv -e .env.test -- vitest --config vitest.e2e.config.ts --watch",
    "test:db:setup": "./scripts/test-db-setup.sh",
    "test:db:seed": "dotenv -e .env.test -- tsx scripts/test-db-seed.ts",
    "test:db:reset": "npm run test:db:setup && npm run test:db:seed",
    "pretest:e2e": "npm run test:db:reset"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.4.20",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/swagger": "^7.4.2",
    "@organizoptera/billing": "workspace:*",
    "@organizoptera/curriculoptera-adapter": "workspace:*",
    "@organizoptera/resources": "workspace:*",
    "@organizoptera/subscription": "workspace:*",
    "@organizoptera/types": "workspace:*",
    "@prisma/client": "^6.19.1",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.20",
    "@swc/core": "^1.15.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^4.17.21",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^4.0.16",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
